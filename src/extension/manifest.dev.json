{
  "manifest_version": 3,
  "name": "Crawlio (Dev)",
  "version": "1.2.0.1",
  "description": "Capture Browser Data via MCP",
  "permissions": [
    "alarms",
    "debugger",
    "storage"
  ],
  "optional_permissions": [
    "tabs"
  ],
  "optional_host_permissions": [
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png",
      "256": "icon256.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png",
    "256": "icon256.png"
  }
}
